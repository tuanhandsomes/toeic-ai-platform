{
  "info": {
    "name": "TOEIC AI Platform",
    "description": "Local API collection. Run Login first to populate {{accessToken}}, then any other request will use it automatically.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000/api/v1" },
    { "key": "accessToken", "value": "" },
    { "key": "refreshToken", "value": "" },
    { "key": "resultId", "value": "REPLACE_WITH_FULL_TEST_RESULT_ID" },
    { "key": "resetToken", "value": "PASTE_TOKEN_FROM_EMAIL_OR_DB_AFTER_FORGOT" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }]
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Logout (revokes refresh token)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/auth/logout", "host": ["{{baseUrl}}"], "path": ["auth", "logout"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            }
          }
        },
        {
          "name": "Refresh access token",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/auth/refresh", "host": ["{{baseUrl}}"], "path": ["auth", "refresh"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            }
          }
        },
        {
          "name": "Forgot password (sends reset email)",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/auth/forgot-password", "host": ["{{baseUrl}}"], "path": ["auth", "forgot-password"] },
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"dokhactuan2808@gmail.com\"\n}" },
            "description": "Always returns 200 to prevent email enumeration. Check inbox or DB collection passwordresettokens for the actual token."
          }
        },
        {
          "name": "Reset password (uses token from email)",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/auth/reset-password", "host": ["{{baseUrl}}"], "path": ["auth", "reset-password"] },
            "body": { "mode": "raw", "raw": "{\n  \"token\": \"{{resetToken}}\",\n  \"newPassword\": \"NewSecret123\"\n}" },
            "description": "Reset password using the token. Also revokes all refresh tokens of the user."
          }
        },
        {
          "name": "Login (auto-save token)",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth", "login"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"dokhactuan2808@gmail.com\",\n  \"password\": \"REPLACE_WITH_YOUR_PASSWORD\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.success && json.data) {",
                  "  pm.collectionVariables.set('accessToken', json.data.accessToken);",
                  "  pm.collectionVariables.set('refreshToken', json.data.refreshToken);",
                  "  console.log('Token saved. User:', json.data.user.email);",
                  "} else {",
                  "  console.error('Login failed:', json);",
                  "}",
                  "pm.test('Login succeeded', () => pm.expect(json.success).to.be.true);"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Stats",
      "item": [
        {
          "name": "GET /stats/overview",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/stats/overview", "host": ["{{baseUrl}}"], "path": ["stats", "overview"] }
          }
        },
        {
          "name": "GET /stats/progress (range=30d)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/stats/progress?range=30d",
              "host": ["{{baseUrl}}"],
              "path": ["stats", "progress"],
              "query": [{ "key": "range", "value": "30d", "description": "7d | 30d | 90d | all" }]
            }
          }
        },
        {
          "name": "GET /stats/parts (testType=all)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/stats/parts?testType=all",
              "host": ["{{baseUrl}}"],
              "path": ["stats", "parts"],
              "query": [{ "key": "testType", "value": "all", "description": "full | part | all" }]
            }
          }
        }
      ]
    },
    {
      "name": "AI",
      "item": [
        {
          "name": "POST /ai/analyze/:resultId (regenerate, 5/hour limit)",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{baseUrl}}/ai/analyze/{{resultId}}",
              "host": ["{{baseUrl}}"],
              "path": ["ai", "analyze", "{{resultId}}"]
            },
            "description": "Force-regenerate analysis. Replace {{resultId}} with a real full-test result _id. Rate-limited to 5/hour/user."
          }
        },
        {
          "name": "GET /ai/analysis/:resultId",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/ai/analysis/{{resultId}}",
              "host": ["{{baseUrl}}"],
              "path": ["ai", "analysis", "{{resultId}}"]
            },
            "description": "Get existing analysis. Lazy-generates if missing and result is full-test."
          }
        }
      ]
    },
    {
      "name": "Tests",
      "item": [
        {
          "name": "GET /tests (user list, only published)",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/tests?type=full", "host": ["{{baseUrl}}"], "path": ["tests"], "query": [{ "key": "type", "value": "full", "description": "full | part" }] }
          }
        },
        {
          "name": "GET /tests?adminView=true (admin sees all, populated)",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/tests?adminView=true", "host": ["{{baseUrl}}"], "path": ["tests"], "query": [{ "key": "adminView", "value": "true" }] }
          }
        },
        {
          "name": "GET /tests/:id (user, taking mode hides answers)",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/tests/REPLACE_TEST_ID", "host": ["{{baseUrl}}"], "path": ["tests", "REPLACE_TEST_ID"] }
          }
        },
        {
          "name": "POST /tests (admin create)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/tests", "host": ["{{baseUrl}}"], "path": ["tests"] },
            "body": { "mode": "raw", "raw": "{\n  \"title\": \"Test mới\",\n  \"type\": \"part\",\n  \"part\": 1,\n  \"questionIds\": [],\n  \"durationMinutes\": 30\n}" }
          }
        }
      ]
    },
    {
      "name": "Questions",
      "item": [
        {
          "name": "GET /questions (admin list)",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/questions?part=1&limit=10", "host": ["{{baseUrl}}"], "path": ["questions"], "query": [{ "key": "part", "value": "1" }, { "key": "limit", "value": "10" }] }
          }
        },
        {
          "name": "POST /questions/import (bulk)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/questions/import", "host": ["{{baseUrl}}"], "path": ["questions", "import"] },
            "body": { "mode": "raw", "raw": "{\n  \"questions\": [],\n  \"defaultTags\": [\"manual\"]\n}" }
          }
        }
      ]
    },
    {
      "name": "Upload",
      "item": [
        {
          "name": "POST /upload/audio (admin)",
          "request": {
            "method": "POST",
            "url": { "raw": "{{baseUrl}}/upload/audio", "host": ["{{baseUrl}}"], "path": ["upload", "audio"] },
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "file", "type": "file", "description": "mp3/wav/m4a/ogg, max 10MB" }
              ]
            },
            "description": "Upload an audio file. Returns Cloudinary secure URL to paste into Question.content.audioUrl."
          }
        },
        {
          "name": "POST /upload/image (admin)",
          "request": {
            "method": "POST",
            "url": { "raw": "{{baseUrl}}/upload/image", "host": ["{{baseUrl}}"], "path": ["upload", "image"] },
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "file", "type": "file", "description": "jpg/png/webp, max 5MB" }
              ]
            },
            "description": "Upload an image. Returns Cloudinary secure URL."
          }
        }
      ]
    },
    {
      "name": "Admin",
      "item": [
        {
          "name": "GET /admin/stats (system-wide)",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/admin/stats", "host": ["{{baseUrl}}"], "path": ["admin", "stats"] },
            "description": "System stats: user count, test count, question count, recent results. Admin only."
          }
        },
        {
          "name": "GET /admin/users (list)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/admin/users?page=1&limit=20",
              "host": ["{{baseUrl}}"],
              "path": ["admin", "users"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "20" },
                { "key": "role", "value": "user", "disabled": true, "description": "user | admin" },
                { "key": "isActive", "value": "true", "disabled": true, "description": "true | false" },
                { "key": "search", "value": "", "disabled": true, "description": "search by fullName or email" }
              ]
            }
          }
        },
        {
          "name": "GET /admin/users/:id (detail)",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/admin/users/REPLACE_USER_ID", "host": ["{{baseUrl}}"], "path": ["admin", "users", "REPLACE_USER_ID"] },
            "description": "Get full user detail by ID. Admin only."
          }
        },
        {
          "name": "POST /admin/users (create)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/admin/users", "host": ["{{baseUrl}}"], "path": ["admin", "users"] },
            "body": { "mode": "raw", "raw": "{\n  \"fullName\": \"Nguyễn Văn A\",\n  \"email\": \"newuser@example.com\",\n  \"password\": \"secret123\",\n  \"role\": \"user\",\n  \"targetScore\": 700,\n  \"isActive\": true\n}" },
            "description": "Create a new user (or admin). role defaults to 'user', targetScore to 700, isActive to true. Email must be unique."
          }
        },
        {
          "name": "PATCH /admin/users/:id (update)",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/admin/users/REPLACE_USER_ID", "host": ["{{baseUrl}}"], "path": ["admin", "users", "REPLACE_USER_ID"] },
            "body": { "mode": "raw", "raw": "{\n  \"fullName\": \"Nguyễn Văn A (updated)\",\n  \"targetScore\": 800,\n  \"role\": \"user\"\n}" },
            "description": "Partial update. Allowed fields: fullName, email, targetScore, role. Body must have ≥1 field. Changing role revokes all refresh tokens of that user. Cannot change own role. Cannot demote the last active admin."
          }
        },
        {
          "name": "DELETE /admin/users/:id",
          "request": {
            "method": "DELETE",
            "url": { "raw": "{{baseUrl}}/admin/users/REPLACE_USER_ID", "host": ["{{baseUrl}}"], "path": ["admin", "users", "REPLACE_USER_ID"] },
            "description": "Hard delete user + cascade Result, AIAnalysis, RefreshToken, PasswordResetToken. Cannot delete self. Cannot delete the last active admin."
          }
        },
        {
          "name": "PATCH /admin/users/:id/lock (lock or unlock)",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/admin/users/REPLACE_USER_ID/lock", "host": ["{{baseUrl}}"], "path": ["admin", "users", "REPLACE_USER_ID", "lock"] },
            "body": { "mode": "raw", "raw": "{\n  \"isActive\": false\n}" },
            "description": "Set isActive=false to lock, true to unlock. Locking also revokes all refresh tokens of that user. Cannot lock the last active admin."
          }
        },
        {
          "name": "PATCH /admin/users/:id/reset-password",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/admin/users/REPLACE_USER_ID/reset-password", "host": ["{{baseUrl}}"], "path": ["admin", "users", "REPLACE_USER_ID", "reset-password"] },
            "body": { "mode": "raw", "raw": "{\n  \"newPassword\": \"newSecret123\"\n}" },
            "description": "Admin force-resets a user's password. Revokes all refresh tokens of that user to force re-login."
          }
        }
      ]
    }
  ]
}
