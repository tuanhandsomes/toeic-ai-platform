# Server
PORT=5000
NODE_ENV=development

# MongoDB Atlas — lấy connection string từ Atlas → Connect → Drivers
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/toeic-ai?retryWrites=true&w=majority

# JWT — tạo bằng `node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"`
JWT_ACCESS_SECRET=replace_me_with_64_byte_random_hex
JWT_REFRESH_SECRET=replace_me_with_another_64_byte_random_hex
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# OpenAI — lấy từ https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-...
OPENAI_MODEL=gpt-4o-mini

# Resend (email service) — lấy từ https://resend.com/api-keys
# Free tier dùng từ onboarding@resend.dev; production cần verify domain riêng
RESEND_API_KEY=re_...
EMAIL_FROM=onboarding@resend.dev
EMAIL_FROM_NAME=TOEIC AI Platform

# CORS — frontend URL
CLIENT_URL=http://localhost:5173
